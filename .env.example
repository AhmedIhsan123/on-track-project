# Copy this file to .env and fill in your values.
# This file is loaded by Docker Compose for both the backend and frontend containers.

# ── Backend ───────────────────────────────────────────────
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
JWT_SECRET=replace-with-a-random-secret
PORT=3001

# ── Frontend (Vite requires the VITE_ prefix) ─────────────
# VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY are the same
# values as above — just duplicated with the Vite prefix.
VITE_API_URL=http://localhost:3001
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...
