{
  "name": "on-track-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test": "vitest",
    "test:run": "vitest run"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "ext": "js,json",
    "ignore": [
      "node_modules"
    ]
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.104.1",
    "axios": "^1.15.2",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-async-errors": "^3.1.1",
    "puppeteer": "^24.42.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "nodemon": "^3.1.9",
    "prettier": "^3.8.3",
    "vitest": "^3.0.0"
  }
}
